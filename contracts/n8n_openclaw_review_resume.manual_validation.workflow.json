      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        280
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{ $json.platform_base_url + '/system/health' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Trade-Oracle-API-Key",
              "value": "={{ $json.platform_api_key }}"
            },
            {
              "name": "X-Request-ID",
              "value": "={{ $json.run_id }}"
            }
          ]
        },
        "options": {
          "timeout": 15000
        }
      },
      "id": "precheck-resume-health",
      "name": "PRECHECK Platform Health",
