    {
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const now = new Date();\nconst threadId = ($env.TRADE_ORACLE_REVIEW_THREAD_ID || '').trim();\nif (!threadId) {\n  throw new Error('TRADE_ORACLE_REVIEW_THREAD_ID is required. Set it to a real pending-review thread before running the resume workflow.');\n}\nconst runId = ($env.TRADE_ORACLE_REVIEW_RUN_ID || `review_${now.getTime()}`).trim();\nconst cycleId = ($env.TRADE_ORACLE_REVIEW_CYCLE_ID || runId).trim();\nreturn [{json:{run_id:runId,cycle_id:cycleId,benchmark_variant:$env.TRADE_ORACLE_BENCHMARK_VARIANT||'super_brain',execution_backend:$env.TRADE_ORACLE_EXECUTION_BACKEND||'mt5',scheduled_at_utc:now.toISOString(),platform_base_url:$env.TRADE_ORACLE_PLATFORM_BASE_URL||'http://host.docker.internal:8000',platform_api_key:$env.TRADE_ORACLE_PLATFORM_API_KEY||'',thread_id:threadId,human_decision:{action:$env.TRADE_ORACLE_REVIEW_ACTION||'APPROVE',reviewer:$env.TRADE_ORACLE_REVIEWER||'openclaw',notes:$env.TRADE_ORACLE_REVIEW_NOTES||'Approved from n8n manual resume validation.'},account_state:{current_balance:Number($env.TRADE_ORACLE_CURRENT_BALANCE||5200),highest_equity:Number($env.TRADE_ORACLE_HIGHEST_EQUITY||5300),active_trades_count:Number($env.TRADE_ORACLE_ACTIVE_TRADES_COUNT||0)}}}];"
      },
      "id": "ctx-resume-runtime",
