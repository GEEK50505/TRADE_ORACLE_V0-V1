      "name": "BRAIN Review Resume",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1260,
        280
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const runtime=$('BRAIN Build Review Resume Request').first().json;const response=$input.first().json;const result=response.result||{};const candidate=result.candidate||null;return [{json:{...runtime,response,result,candidate,run_id:result.run_id||runtime.run_id||'',cycle_id:result.cycle_id||runtime.cycle_id||'',benchmark_variant:result.benchmark_variant||runtime.benchmark_variant||'super_brain',candidate_ready:Boolean(candidate&&candidate.execute_trade===true&&candidate.execution_status==='approved')}}];"
      },
