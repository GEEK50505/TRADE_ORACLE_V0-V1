      "typeVersion": 4.2,
      "position": [
        740,
        280
      ]
    },
    {
      "parameters": {
        "language": "javaScript",
        "mode": "runOnceForAllItems",
        "jsCode": "const runtime=$('CTX Resolve Resume Context').first().json;const health=$input.first().json;return [{json:{...runtime,precheck_health:health,review_resume_request:{run_id:runtime.run_id,cycle_id:runtime.cycle_id,benchmark_variant:runtime.benchmark_variant,thread_id:runtime.thread_id,human_decision:runtime.human_decision}}}];"
      },
      "id": "brain-build-resume-request",
      "name": "BRAIN Build Review Resume Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1000,
        280
      ]
