        "jsCode": "const trigger=$('CTX Parse Telegram Callback').first().json;const rowItems=$('STATE Lookup Pending Review Row').all();const stored=rowItems[0]?.json||{};const audit=$input.first().json;const auditEvents=Array.isArray(audit.events)?audit.events:[];const latest=auditEvents[0]||{};const safeParse=(value)=>{if(!value||typeof value!=='string'){return {};}try{return JSON.parse(value);}catch{return {};}};const storedCandidate=safeParse(stored.candidate_json);const storedReviewContext=safeParse(stored.review_context_json);const storedAccountState=safeParse(stored.account_state_json);const evaluationPayload=latest.payload||{};const rawSetup=evaluationPayload.raw_setup||storedCandidate.raw_setup||{};const runId=stored.run_id||latest.run_id||`review_${Date.now()}`;const cycleId=stored.cycle_id||runId;const accountState={current_balance:Number(storedAccountState.current_balance||rawSetup.account_state?.current_balance||$env.TRADE_ORACLE_CURRENT_BALANCE||5200),highest_equity:Number(storedAccountState.highest_equity||rawSetup.account_state?.highest_equity||$env.TRADE_ORACLE_HIGHEST_EQUITY||5300),active_trades_count:Number(storedAccountState.active_trades_count||rawSetup.account_state?.active_trades_count||$env.TRADE_ORACLE_ACTIVE_TRADES_COUNT||0)};return [{json:{run_id:runId,cycle_id:cycleId,benchmark_variant:stored.benchmark_variant||trigger.benchmark_variant||'super_brain',execution_backend:trigger.execution_backend||$env.TRADE_ORACLE_EXECUTION_BACKEND||'mt5',platform_base_url:trigger.platform_base_url,platform_api_key:trigger.platform_api_key,thread_id:trigger.thread_id,telegram_chat_id:trigger.telegram_chat_id,telegram_message_id:trigger.telegram_message_id,callback_query_id:trigger.callback_query_id,human_decision:{action:trigger.review_action,reviewer:trigger.reviewer,notes:trigger.review_notes},candidate:Object.keys(storedCandidate).length?storedCandidate:(evaluationPayload.candidate||null),stored_review_context:storedReviewContext,account_state:accountS