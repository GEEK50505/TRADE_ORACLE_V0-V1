        "jsCode": "const update=$input.first().json;const callback=update.callback_query||{};const rawData=String(callback.data||'').trim();if(!rawData){throw new Error('Telegram callback query is missing callback data.');}const [actionToken,...rest]=rawData.split(':');const threadId=rest.join(':').trim();if(!threadId){throw new Error('Telegram callback data does not include a thread id.');}const action=String(actionToken||'').trim().toLowerCase();if(!['approve','reject'].includes(action)){throw new Error(`Unsupported Telegram review action: ${actionToken}`);}const reviewer=callback.from?.username?`@${callback.from.username}`:(callback.from?.first_name||'telegram_reviewer');const notes=`${action==='approve'?'Approved':'Rejected'} from Telegram by ${reviewer}.`;return [{json:{thread_id:threadId,review_action:action==='approve'?'APPROVE':'REJECT',reviewer,review_notes:notes,callback_query_id:String(callback.id||''),telegram_chat_id:String(callback.message?.chat?.id||''),telegram_message_id:String(callback.message?.message_id||''),platform_base_url:$env.TRADE_ORACLE_PLATFORM_BASE_URL||'http://host.docker.internal:8000',platform_api_key:$env.TRADE_ORACLE_PLATFORM_API_KEY||'',execution_backend:$env.TRADE_ORACLE_EXECUTION_BACKEND||'mt5',benchmark_variant:$env.TRADE_ORACLE_BENCHMARK_VARIANT||'super_brain',received_at_utc:new Date().toISOString()}}];"
