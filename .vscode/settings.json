{
  // use the venv interpreter generated by this project
  "python.defaultInterpreterPath": "${workspaceFolder}\\venv\\Scripts\\python.exe",
  
  // keep linting enabled as before
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": true,

  // configure integrated terminal so it automatically activates our venv
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "args": [
        "-NoExit",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "cd \"${workspaceFolder}\"; .\\venv\\Scripts\\Activate.ps1"
      ]
    },
    "Command Prompt": {
      "path": "cmd.exe",
      "args": ["/k", "cd /d ${workspaceFolder} && venv\\Scripts\\Activate.bat"]
    }
  },

  "terminal.integrated.env.windows": {
    "VIRTUAL_ENV": "${workspaceFolder}\\venv"
  },

  // ensure terminals open in project root
  "terminal.integrated.cwd": "${workspaceFolder}",

  // automatically activate the selected env when a new terminal is created
  "python.terminal.activateEnvironment": true
}
